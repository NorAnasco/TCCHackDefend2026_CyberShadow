<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0B0F14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header logo & Premium Brand block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <!-- Premium Brand Icon with glowing borders -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="42dp"
                app:cardCornerRadius="21dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#00C896">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="68dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="19dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#0B0F14">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="S"
                            android:textColor="#00C896"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="P"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginStart="2dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_marginStart="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SP "
                        android:textColor="#00C896"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SENTINEL"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protection nationale contre les arnaques et fraudes"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="2dp" />

                <!-- Dynamic Status Badge Capsule -->
                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#111827"
                    android:layout_marginTop="8dp">
                    
                    <TextView
                        android:id="@+id/tvStatusHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟢 SURVEILLANCE ACTIVE"
                        android:textColor="#00C896"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Sophisticated settings icon -->
            <ImageButton
                android:id="@+id/btnOpenSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_preferences"
                android:tint="#1B2434"
                android:contentDescription="Paramètres"
                android:layout_gravity="top" />
        </LinearLayout>

        <!-- SECURITY RISK ALERT PANEL (Permissions warning) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tvPermissionWarningLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#221215"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <!-- Outer subtle red glowing effect simulating high risk -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:id="@+id/imgWarningIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/stat_sys_warning"
                        android:tint="#EF4444" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="SÉCURITÉ DU SYSTÈME EN ATTENTE"
                        android:textColor="#EF4444"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPermissionWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="L'agent de sécurité ne pourra pas analyser et bloquer les arnaques de vol d'argent sur WhatsApp ou SMS sans les autorisations requises."
                    android:textColor="#FCA5A5"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="4dp" />

                <Button
                    android:id="@+id/btnEnablePermission"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="ACTIVER LA PROTECTION IMMÉDIATEMENT"
                    android:backgroundTint="#EF4444"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SECURITY INSTRUMENTATION DIAGRAM (Visual premium divider) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#111827"
            android:layout_marginBottom="24dp">
            
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="1dp"
                app:cardCornerRadius="19dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0B0F14">

                <!-- Tech visual representation resembling a SOC live shield radar -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CYBER-RÉSEAU"
                            android:textColor="#94A3B8"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bouclier Actif"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-condensed-light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Filtrage sémantique temps réel"
                            android:textColor="#00C896"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <!-- Shield Graphic Circle Radar on the right -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#161E2E"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true">
                        
                        <androidx.cardview.widget.CardView
                            android:layout_width="82dp"
                            android:layout_height="82dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="41dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#0B0F14">
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🛡️"
                                    android:textSize="26sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SÉCURISÉ"
                                    android:textColor="#00C896"
                                    android:textSize="8sp"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.05"
                                    android:layout_marginTop="2dp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>

        <!-- Stats Dashboard Block with card shapes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="24dp">

            <!-- Card 1: Blocked threats -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#1C1E24"
                android:layout_marginEnd="8dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#111827">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PIÈGES ÉVITÉS"
                            android:textColor="#94A3B8"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.1"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvBlockedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#EF4444"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginTop="4dp" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tentatives bloquées"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Security points/signatures count -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#1C1E24"
                android:layout_marginStart="8dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    app:cardCornerRadius="17dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#111827">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ARNAQUES CONNUES"
                            android:textColor="#94A3B8"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.1"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSignaturesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#00C896"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profils malveillants"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Big Simplified Security Status Button (Protecteur) -->
        <Button
            android:id="@+id/btnSyncNow"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="🔴 SÉCURITÉ INACTIVE\n(Touchez ici pour activer la protection)"
            android:backgroundTint="#EF4444"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:lineSpacingExtra="3sp"
            android:elevation="6dp"
            android:layout_marginBottom="16dp"
            app:cornerRadius="18dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✓ Fonctionne en toute sécurité sans consommer votre connexion internet."
            android:textColor="#64748B"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:fontFamily="sans-serif" />

        <!-- Footer status -->
        <TextView
            android:id="@+id/tvLastUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dernier contrôle de sécurité effectué : Jamais"
            android:textColor="#475569"
            android:textSize="11sp"
            android:gravity="center"
            android:fontFamily="monospace"
            android:layout_marginTop="10dp" />

        <!-- Institutional Trust Assurance Footer Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="40dp"
            android:alpha="0.6">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️ SP_TG SENTINEL CODES"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.05" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
